---
import FullPageLayout from '@/layouts/FullPageLayout.astro';
import type { Page } from '@/types';
import PageWrapper from '@/components/common/PageWrapper.vue';
import Navbar from "@/components/sections/global/Navbar.vue";
import Pricing from "@/components/sections/pricing/Pricing.vue";
import Testimonial from "@/components/sections/pricing/Testimonial.vue";
import Footer from "@/components/sections/global/Footer.vue";


const page = {
  "seo": {
    "title": "",
    "description": ""
  },
  "id": "pricing",
  "link": "pricing",
  "sections": []
} as Page;;
---

<FullPageLayout seo={page.seo}>
  <PageWrapper
    client:load
    page={page}>
    <!-- Page Sections -->
    <Navbar client:load />
<Pricing client:load />
<Testimonial client:load />
<Footer client:load />

  </PageWrapper>
</FullPageLayout>
